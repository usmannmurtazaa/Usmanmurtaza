{
  "name": "usman-murtaza-portfolio",
  "version": "2.0.0",
  "private": true,
  "description": "Professional portfolio of Usman Murtaza - Full Stack & React Developer specializing in modern web applications, responsive design, and web performance optimization.",
  "keywords": [
    "react",
    "portfolio",
    "developer",
    "full-stack",
    "frontend",
    "javascript",
    "web-development",
    "react-developer",
    "seo-optimized",
    "responsive-design"
  ],
  "author": {
    "name": "Usman Murtaza",
    "email": "usmanmurtazaportfolio@gmail.com",
    "url": "https://usmanmurtaza.netlify.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/usmannmurtazaa/Usmanmurtaza"
  },
  "bugs": {
    "url": "https://github.com/Usmannmurtazaa/Usmanmurtaza/issues"
  },
  "homepage": "https://usmanmurtaza.netlify.app",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@emailjs/browser": "^4.3.3",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/lab": "^5.0.0-alpha.165",
    "@mui/material": "^5.15.17",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.544.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.23.1",
    "react-scripts": "^5.0.1",
    "styled-components": "^6.1.12",
    "typewriter-effect": "^2.22.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/styled-components": "^5.1.34",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.11",
    "gh-pages": "^6.3.0",
    "prettier": "^3.8.1",
    "web-vitals": "^3.5.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:analyze": "npm run build && npx source-map-explorer 'build/static/js/*.js' --html build-report.html",
    "build:production": "GENERATE_SOURCEMAP=false react-scripts build",
    "test": "react-scripts test --watchAll=false",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "test:watch": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src/**/*.{js,jsx}",
    "lint:fix": "eslint src/**/*.{js,jsx} --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css,md}\"",
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "prebuild": "npm audit --production",
    "deploy": "gh-pages -d build",
    "deploy:netlify": "npm run build:production",
    "clean": "rm -rf node_modules build dist coverage",
    "clean:install": "npm run clean && npm ci",
    "audit:fix": "npm audit fix",
    "type-check": "tsc --noEmit"
  },
  "resolutions": {
    "styled-components": "^6.1.12",
    "nth-check": "2.1.1",
    "postcss": "8.4.38",
    "webpack-dev-server": "4.15.1"
  },
  "overrides": {
    "nth-check": "2.1.1",
    "postcss": "8.4.38",
    "webpack-dev-server": "4.15.1"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "plugins": [
      "react-hooks",
      "react-refresh"
    ],
    "rules": {
      "react-hooks/rules-of-hooks": "error",
      "react-hooks/exhaustive-deps": "warn",
      "react-refresh/only-export-components": "warn"
    },
    "settings": {
      "react": {
        "version": "detect"
      }
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not ie > 0",
      "not ie_mob > 0",
      "not baidu > 0",
      "not kaios > 0",
      "not and_uc > 0"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version",
      "last 1 edge version"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/index.js",
      "!src/reportWebVitals.js",
      "!src/setupTests.js",
      "!src/**/*.test.{js,jsx}",
      "!src/**/index.{js,jsx}"
    ]
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "bracketSpacing": true,
    "jsxBracketSameLine": false,
    "arrowParens": "avoid"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
